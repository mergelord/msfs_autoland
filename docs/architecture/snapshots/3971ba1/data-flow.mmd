flowchart LR
    subgraph Source["SimConnect Source"]
        SIM["SimConnect get_all_data()"]
    end
    subgraph Telemetry["Telemetry Dict"]
        POS["position: lat/lon/alt_agl/rh"]
        SPD["speed: ias/gs/vs"]
        ATT["attitude: heading/bank/pitch"]
        NAV["nav: nav1_freq/dme/cdi"]
        ILS["ils: loc/gs/dev"]
    end
    subgraph Calc["Calculation Modules"]
        NAV_MOD["navigation.py"]
        ILS_MOD["ils_navigation.py"]
        WIND["wind_correction.py"]
        SYNTH["synthetic_glidepath.py"]
        SPEED["approach_speed_calculator.py"]
    end
    subgraph Phase["Phase Logic"]
        PHASE["approach_phases.py"]
    end
    subgraph Output["Actuator Commands"]
        HDG["heading"]
        VS["vertical_speed"]
        THR["throttle"]
        FLAPS["flaps/gear"]
    end
    SIM --> POS
    SIM --> SPD
    SIM --> ATT
    SIM --> NAV
    SIM --> ILS
