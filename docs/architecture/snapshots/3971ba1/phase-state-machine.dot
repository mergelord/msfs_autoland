digraph phase_state_machine {
    rankdir=TB;
    node [shape=box, style=filled, fontname="Arial", fontsize=10];

    IDLE [label="IDLE\nmain.py:98", fillcolor="#f5f5f5", color="#999999"];
    INITIAL [label="INITIAL\nInitialPhaseState\napproach_phases.py:45", fillcolor="#c8e6c9"];
    INTERMEDIATE [label="INTERMEDIATE\nIntermediatePhaseState\napproach_phases.py:80", fillcolor="#c8e6c9"];
    FINAL [label="FINAL\nFinalPhaseState\napproach_phases.py:250", fillcolor="#c8e6c9"];
    LANDING [label="LANDING\nLandingPhaseState\napproach_phases.py:624", fillcolor="#ffe0b2"];
    COMPLETED [label="COMPLETED\nmain.py:820", fillcolor="#bbdefb"];

    IDLE -> INITIAL [label="start_approach()"];
    INITIAL -> INTERMEDIATE [label="on_course AND dme<15"];
    INTERMEDIATE -> FINAL [label="ILS: on_localizer\nnon-ILS: takeover done\n+ dist<8 + alt match"];
    FINAL -> LANDING [label="radio_height < DH\n+ takeover confirmed\n+ stabilized"];
    LANDING -> COMPLETED [label="radio_height < 3ft"];

    INTERMEDIATE -> IDLE [label="takeover fail", style=dashed, color="#e91e63"];
    FINAL -> IDLE [label="SafetyGuard GO_AROUND\nstabilization fail\nwind shear/turbulence\nDH guard\nerror budget", style=dashed, color="#e91e63"];
}
